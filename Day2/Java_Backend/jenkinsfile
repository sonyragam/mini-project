pipeline {
    agent any

    environment {
        APP_DIR = "/tmp/springapp"
        JAR_NAME = "app.jar"
    }

    stages {

        stage('Checkout Code') {
            steps {
                echo "Cloning repository..."
                git branch: 'main', url: 'YOUR_GIT_REPO_URL'
            }
        }

        stage('Build Jar') {
            steps {
                echo "Building Spring Boot application..."

                sh '''
                ./mvnw clean package -DskipTests || mvn clean package -DskipTests
                '''
            }
        }

        stage('Prepare Deployment Directory') {
            steps {
                sh '''
                echo "Creating deployment directory..."
                mkdir -p $APP_DIR
                '''
            }
        }

        stage('Deploy Jar') {
            steps {
                sh '''
                echo "Copying jar to /tmp..."

                cp target/*.jar $APP_DIR/$JAR_NAME

                echo "Stopping old app if running..."
                pkill -f $JAR_NAME || true
                '''
            }
        }

        stage('Run Application (Detached)') {
            steps {
                sh '''
                echo "Starting Spring Boot application in detached mode..."

                cd $APP_DIR

                nohup setsid bash -c "
                java -jar $JAR_NAME > app.log 2>&1 < /dev/null
                " &

                echo $! > app.pid

                sleep 5

                echo "Checking if application started..."
                ps -ef | grep $JAR_NAME || true
                ss -tulnp | grep 9090 || true
                '''
            }
        }

    }

    post {
        success {
            echo "Deployment successful!"
        }

        failure {
            echo "Deployment failed!"
        }
    }
}
