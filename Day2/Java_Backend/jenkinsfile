pipeline {
    agent any

    stages {

        stage('Build') {
            steps {
                dir('Day2/Java_Backend') {
                    sh '''
                    echo "Building application..."
                    mvn clean package
                    '''
                }
            }
        }

        stage('Deploy') {
            steps {
                dir('Day2/Java_Backend') {
                    sh '''
                    set -e

                    echo "Checking Java..."
                    java -version || true

                    echo "Stopping existing application on port 9090..."
                    fuser -k 9090/tcp || true

                    echo "Validating JAR file..."

                    JAR="target/simple_java-1.0.jar"

                    if [ ! -f "$JAR" ]; then
                        echo "ERROR: JAR not found at $JAR"
                        exit 1
                    fi

                    echo "Starting application..."

                    # Start Spring Boot in background (correct way)
                    nohup java -jar $JAR > app.log 2>&1 &

                    echo $! > app.pid

                    sleep 5

                    echo "Checking running Java processes..."
                    ps -ef | grep java | grep -v grep || true

                    echo "Checking port 9090..."
                    lsof -i :9090 || true

                    echo "Application logs (last 30 lines):"
                    tail -n 30 app.log || true

                    echo "Deployment completed successfully"
                    '''
                }
            }
        }
    }
}
