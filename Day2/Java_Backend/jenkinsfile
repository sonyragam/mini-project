pipeline {
    agent any

    environment {
        SONAR_PROJECT_KEY = 'test-backend'
    }

    stages {

        stage('Build Jar') {
            steps {
                echo "Building Spring Boot JAR..."

                sh '''
                cd /home/sony/.jenkins/workspace/test/Day2/Java_Backend
                mvn clean package -DskipTests
                '''
            }
        }

        stage('Verify') {
            steps {
                echo "Checking target folder..."

                sh '''
                ls -lh /home/sony/.jenkins/workspace/test/Day2/Java_Backend/target/
                '''
            }
        }

        stage('SonarQube Analysis') {
            steps {
                echo "Running SonarQube Analysis..."

                withSonarQubeEnv('sonar_qube') {

                    sh '''
                    cd /home/sony/.jenkins/workspace/test/Day2/Java_Backend
                    mvn clean verify sonar:sonar \
                    -Dsonar.projectKey=$SONAR_PROJECT_KEY \
                    -Dsonar.host.url=http://localhost:9000
                    '''
                }
            }
        }

        stage('Docker Build') {
            steps {
                echo "Building Docker Image..."

                sh '''
                cd /home/sony/.jenkins/workspace/test/Day2/Java_Backend
                docker build -t java-backend-app .
                '''
            }
        }

        stage('Run Docker Container') {
            steps {
                echo "Stopping old container if exists..."

                sh '''
                docker stop java-backend-container || true
                docker rm java-backend-container || true
                '''

                echo "Running new container on port 9090..."

                sh '''
                docker run -d -p 9090:9090 \
                --name java-backend-container \
                java-backend-app
                '''
            }
        }

    }

    post {
        success {
            echo "Build + SonarQube + Docker pipeline successful"
        }

        failure {
            echo "Pipeline failed"
        }
    }
}
