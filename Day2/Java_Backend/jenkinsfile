pipeline {
    agent any

    stages {

        stage('Build') {
            steps {
                dir('Day2/Java_Backend') {
                    sh '''
                    echo "Building application..."
                    mvn clean package
                    '''
                }
            }
        }

        stage('Deploy') {
            steps {
                dir('Day2/Java_Backend') {
                    sh '''
                    echo "Stopping old application..."
                    fuser -k 9090/tcp || true

                    echo "Starting new application..."
                    setsid java -jar target/simple_java-1.0.jar > app.log 2>&1 &

                    echo "Application deployed successfully"
                    '''
                }
            }
        }
    }
}
