 pipeline {
    agent any

    stages {

        stage('Build Jar') {
            steps {
                echo "Building Spring Boot JAR..."

                sh '''
                cd /home/sony/.jenkins/workspace/test/Day2/Java_Backend 
                mvn clean package -DskipTests
                '''
            }
        }

        stage('Verify') {
            steps {
                echo "Checking target folder..."

                sh '''
                ls -lh /home/sony/Day2/Java_Backend/target/
                '''
            }
        }

    }

    post {
        success {
            echo "Build successful - JAR created in target/"
        }

        failure {
            echo "Build failed"
        }
    }
}
