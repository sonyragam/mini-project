pipeline {
    agent any

    environment {
        SONAR_PROJECT_KEY = 'test-backend'
        IMAGE = 'sonyragam/java-backend-app'
    }

    stages {

        stage('Build Jar') {
            steps {
                echo "Building Spring Boot JAR..."

                sh '''
                cd /home/sony/.jenkins/workspace/test/Day2/Java_Backend
                mvn clean package -DskipTests
                '''
            }
        }

        stage('Verify') {
            steps {
                echo "Checking target folder..."

                sh '''
                ls -lh /home/sony/.jenkins/workspace/test/Day2/Java_Backend/target/
                '''
            }
        }

        stage('SonarQube Analysis') {
            steps {
                echo "Running SonarQube Analysis..."

                withSonarQubeEnv('sonar_qube') {
                    sh '''
                    cd /home/sony/.jenkins/workspace/test/Day2/Java_Backend
                    mvn verify sonar:sonar \
                    -Dsonar.projectKey=$SONAR_PROJECT_KEY \
                    -Dsonar.host.url=http://localhost:9000
                    '''
                }
            }
        }

        stage('Generate Tag') {
            steps {
                script {
                    def COMMIT = sh(script: "git rev-parse --short HEAD", returnStdout: true).trim()
                    def TAG = "${BUILD_NUMBER}-${COMMIT}"
                    env.TAG = TAG
                }
            }
        }

        stage('Docker Build') {
            steps {
                echo "Building Docker Image..."

                sh '''
                cd /home/sony/.jenkins/workspace/test/Day2/Java_Backend
                docker build -t $IMAGE:$TAG .
                '''
            }
        }

        stage('Docker Push') {
            steps {
                echo "Pushing image to Docker Hub..."

                withCredentials([usernamePassword(credentialsId: 'docker', usernameVariable: 'USER', passwordVariable: 'PASS')]) {

                    sh '''
                    echo $PASS | docker login -u $USER --password-stdin
                    docker push $IMAGE:$TAG
                    '''
                }
            }
        }

        stage('Update K8s Deployment') {
            steps {
                echo "Updating deployment.yml with new image tag..."

                withCredentials([usernamePassword(credentialsId: 'git-creds', usernameVariable: 'GIT_USER', passwordVariable: 'GIT_PASS')]) {

                    sh '''
                    cd /home/sony/.jenkins/workspace/test/Day2/Java_Backend

                    # Update image tag in K8s deployment
                    sed -i "s|image:.*|image: sonyragam/java-backend-app:$TAG|" K8s/deployment.yml

                    # Git config
                    git config user.name "jenkins"
                    git config user.email "jenkins@example.com"

                    # Commit and push
                    git add K8s/deployment.yml
                    git commit -m "Update image to $TAG" || echo "No changes to commit"

                    git push https://$GIT_USER:$GIT_PASS@github.com/sonyragam/mini-project.git HEAD:main
                    '''
                }
            }
        }
    }

    post {
        success {
            echo "Build + SonarQube + Docker + GitOps successful"
        }

        failure {
            echo "Pipeline failed"
        }
    }
}
