pipeline {
    agent any

    stages {

        stage('Build') {
            steps {
                dir('Day2/Java_Backend') {
                    sh 'mvn clean package'
                }
            }
        }

        stage('Deploy') {
            steps {
                dir('Day2/Java_Backend') {
                    sh '''
                    fuser -k 9090/tcp || true
                    nohup java -jar target/simple_java-1.0.jar > app.log 2>&1 &
                    '''
                }
            }
        }
    }
}  
