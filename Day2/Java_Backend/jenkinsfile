stage('Deploy') {
    steps {
        sh '''
        set -e

        APP_DIR=/tmp/springboot-app
        mkdir -p $APP_DIR

        echo "Copying jar out of Jenkins workspace..."
        cp Day2/Java_Backend/target/*.jar $APP_DIR/app.jar

        cd $APP_DIR

        echo "Killing old process if exists..."
        pkill -f app.jar || true

        echo "Starting app in FULLY detached mode..."

        nohup setsid java -jar app.jar \
        > app.log 2>&1 < /dev/null &

        disown

        echo $! > app.pid

        sleep 10

        echo "Checking process AFTER Jenkins scope ends..."
        ps -ef | grep app.jar || true
        ss -tulnp | grep 9090 || true
        '''
    }
}
