pipeline {
    agent any

    stages {

        stage('Build') {
            steps {
                dir('Day2/Java_Backend') {
                    sh '''
                    echo "Building application..."
                    mvn clean package
                    '''
                }
            }
        }

        stage('Deploy') {
            steps {
                dir('Day2/Java_Backend') {
                    sh '''
                    set -e

                    echo "Copying jar to stable location..."
                    mkdir -p /tmp/springapp
                    cp target/*.jar /tmp/springapp/app.jar

                    cd /tmp/springapp

                    echo "Stopping old app (if any)..."
                    pkill -f app.jar || true

                    echo "Starting application in detached mode..."

                    setsid nohup java -jar app.jar > app.log 2>&1 < /dev/null &

                    echo $! > app.pid

                    sleep 10

                    echo "Checking process..."
                    ps -ef | grep app.jar | grep -v grep || true

                    echo "Checking port 9090..."
                    ss -tulnp | grep 9090 || true

                    echo "Last logs:"
                    tail -n 50 app.log || true

                    echo "Deployment DONE"
                    '''
                }
            }
        }
    }
}
