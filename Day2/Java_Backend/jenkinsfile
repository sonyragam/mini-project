pipeline {
    agent any

    stages {

        stage('Build & Deploy') {
            steps {
                sh '''
                cd /home/sony/.jenkins/workspace/test

                echo "Stopping old app..."
                fuser -k 9090/tcp || true

                echo "Building new JAR..."
                mvn clean package

                echo "Starting new app..."
                nohup java -jar target/*.jar > app.log 2>&1 &

                echo "App started"
                '''
            }
        }
    }
}
